# --- Image Generation Providers ---

# Poe API key (required for story frame generation + default image generation)
# Get from: https://poe.com/api_key
POE_KEY=your-poe-api-key

# xAI Grok API key (used as fallback image generator)
# Get from: https://console.x.ai
XAI_API_KEY=your-xai-api-key

# Google Gemini API key (optional, for Gemini image generation provider)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# --- API Server ---
API_PORT=5000
